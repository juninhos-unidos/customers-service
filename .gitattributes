# Força o Git a tratar quase tudo como texto e converter para LF no checkout (Linux/Mac)
* text=auto eol=lf

# Garante que scripts e workflows SEMPRE usem LF (essencial para o GitHub Actions)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Mantém arquivos de Windows com CRLF por segurança
*.bat text eol=crlf
*.cmd text eol=crlf